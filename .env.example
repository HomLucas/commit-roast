# ============================================
# NEVER COMMIT REAL .env FILES TO GIT
# Copy this to .env and fill in real values
# ============================================

# API Keys
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret
SKYSCANNER_API_KEY=your_skyscanner_api_key
CURRENCY_API_KEY=your_currencylayer_key

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/flightscanner
REDIS_URL=redis://localhost:6379/0

# Authentication
JWT_SECRET_KEY=use-openssl-rand-hex-32
JWT_REFRESH_SECRET_KEY=use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=use-fernet-generate-key

# Email (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_FROM=noreply@flightscanner.com

# App Config
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Feature Flags
ENABLE_POINTS_TRACKING=true
ENABLE_PRICE_PREDICTION=true
ENABLE_ALERTS=true
MAX_ALERTS_PER_USER=20

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
